{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/login",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": ""
      }
    },
    {
      "path": "pages/wallet/wallet",
      "style": {
        "navigationBarTitleText": "钱包",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/dapp/dapp",
      "style": {
        "navigationBarTitleText": "DApp 浏览器",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/ai/ai",
      "style": {
        "navigationBarTitleText": "AI 助手"
      }
    },
    {
      "path": "pages/transfer/transfer",
      "style": {
        "navigationBarTitleText": "转账"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "交易记录",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/settings/settings",
      "style": {
        "navigationBarTitleText": "设置"
      }
    }
  ],
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#007AFF",
    "borderStyle": "black",
    "backgroundColor": "#F8F8F8",
    "list": [
      {
        "pagePath": "pages/wallet/wallet",
        "iconPath": "static/tabbar/wallet.png",
        "selectedIconPath": "static/tabbar/wallet-active.png",
        "text": "钱包"
      },
      {
        "pagePath": "pages/dapp/dapp",
        "iconPath": "static/tabbar/browser.png",
        "selectedIconPath": "static/tabbar/browser-active.png",
        "text": "DApp"
      },
      {
        "pagePath": "pages/ai/ai",
        "iconPath": "static/tabbar/ai.png",
        "selectedIconPath": "static/tabbar/ai-active.png",
        "text": "AI"
      },
      {
        "pagePath": "pages/settings/settings",
        "iconPath": "static/tabbar/settings.png",
        "selectedIconPath": "static/tabbar/settings-active.png",
        "text": "设置"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "XUL Wallet",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  }
}
