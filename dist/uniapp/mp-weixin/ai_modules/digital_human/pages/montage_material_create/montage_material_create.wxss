.copywriter-item{position:relative;border-radius:16rpx;background-color:var(--color-white, #ffffff);padding:32rpx;--tw-shadow: 0rpx 6rpx 12rpx 0 rgba(0,0,0,.03);--tw-shadow-colored: 0rpx 6rpx 12rpx 0 var(--tw-shadow-color);box-shadow:var(--tw-ring-offset-shadow, 0 0 #0000),var(--tw-ring-shadow, 0 0 #0000),var(--tw-shadow)}.copywriter-item--error{border-width:1px;border-style:solid;border-color:var(--color-error, #f56c6c);background-color:rgba(245,108,108,.5)}.type-item{position:relative;z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:16rpx;font-size:24rpx;color:rgba(0,0,0,.5);transition-property:color,background-color,border-color,text-decoration-color,fill,stroke;transition-timing-function:cubic-bezier(.4,0,.2,1);transition-duration:.5s}.type-item.active{position:relative;font-weight:500;color:var(--color-primary, #0065FB)}.tab-slider{position:absolute;top:6rpx;left:0px;height:calc(100% - 10rpx);width:50%;border-radius:16rpx;background-color:var(--color-white, #ffffff);transition-property:all;transition-timing-function:cubic-bezier(.4,0,.2,1);transition-duration:.5s}
